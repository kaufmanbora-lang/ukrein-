# Copy this file to .env.local for local development.
# Do not commit .env.local or .env with real secrets.

# Required for live diplomacy AI. Create this in OpenAI Platform and paste it locally/Render.
OPENAI_API_KEY=

# Strongest/default diplomacy model. Change in Render if your account uses another model.
OPENAI_MODEL=gpt-5.5
OPENAI_TEMPERATURE=0.93

# Optional. The game works without Google Maps using the built-in tactical map.
GOOGLE_MAPS_API_KEY=

# Local server port. Render sets PORT automatically.
PORT=8787
